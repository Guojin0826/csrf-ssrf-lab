# Git属性配置

# 自动检测文本文件并规范化行尾
* text=auto

# PHP文件
*.php text eol=lf
*.phtml text eol=lf

# HTML/CSS/JS文件
*.html text eol=lf
*.htm text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf

# 文档文件
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# 配置文件
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ini text eol=lf
.htaccess text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Shell脚本
*.sh text eol=lf
*.bash text eol=lf

# 图片文件（二进制）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf

# 压缩文件（二进制）
*.zip binary
*.tar.gz binary
*.rar binary
*.7z binary

# 字体文件（二进制）
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary

# PDF文件（二进制）
*.pdf binary